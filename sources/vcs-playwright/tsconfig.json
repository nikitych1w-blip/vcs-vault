{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "strict": true,
    "noEmit": true,
    "useUnknownInCatchVariables": false,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "lib": ["es2022", "dom"],
    "rootDir": ".",
    "outDir": "./dist",
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@vcs-pw/*": ["src/*"]
    },
    "allowSyntheticDefaultImports": true
  },
  "include": ["src", "tests", "eslint.config.js", "playwright.config.ts", "global.setup.ts", "openapi-ts.config.ts"],
  "exclude": ["node_modules", "dist", "reports", ".git", "playwright-report", "spec"]
}
