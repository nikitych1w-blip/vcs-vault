      "item": [
        {
          "name": "Get Project Access",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has valid access structure\", function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('is_admin');",
                  "    pm.expect(response).to.have.property('project_id');",
                  "    pm.expect(response).to.have.property('project_name');",
                  "    pm.expect(response).to.have.property('group');",
                  "    pm.expect(response).to.have.property('actions');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token_bearer_jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{sc_api_ift_stand_url_external}}/{{sc_api_web_v2_prefix}}/access/projects/{{sc_api_mock_project_name}}",
              "host": [
                "{{sc_api_ift_stand_url_external}}"
              ],
              "path": [
                "{{sc_api_web_v2_prefix}}",
                "access",
                "projects",
                "{{sc_api_mock_project_name}}"
              ]
            }
          },
          "response": []
        },
