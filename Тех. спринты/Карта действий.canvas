		{"id":"02ec7ae398ea7a42","type":"text","text":"Задача smoke крит тестов на АТ","x":-946,"y":-3360,"width":250,"height":60},
		{"id":"b63bdb6119fc60f3","type":"text","text":"Тест автоматизирован?","x":-1320,"y":-3343,"width":250,"height":60},
		{"id":"a2740739c2874f17","type":"text","text":"Задача c меткой Edit в названии на АТ, со ссылкой на действующие АТ тесты","x":-1692,"y":-3700,"width":314,"height":100},
		{"id":"37abf48fa219b736","type":"text","text":"Да","x":-1753,"y":-3500,"width":250,"height":60},
		{"id":"30c06ec1641d2f27","type":"text","text":"Нет","x":-1503,"y":-3500,"width":250,"height":60},
		{"id":"8fcc4c7f40cae60f","type":"text","text":"Тест автоматизирован?","x":-515,"y":-3160,"width":250,"height":60},
		{"id":"34430bff301889b1","type":"text","text":"Да","x":-640,"y":-3300,"width":250,"height":60},
		{"id":"a1c326f9b60c9e60","type":"text","text":"Нет","x":-390,"y":-3300,"width":250,"height":60},
		{"id":"f605ad8700c2a9f1","type":"text","text":"Проставь признак что не автоматизирован в явном виде в поле \"Автоматизирован\"","x":-1349,"y":-3692,"width":279,"height":84},
		{"id":"51be847a80820123","type":"text","text":"Проставь признак что не автоматизирован в явном виде в поле \"Автоматизирован\"","x":-320,"y":-3466,"width":279,"height":84},
