	"nodes":[
		{"id":"194f59f9e5fb67de","type":"text","text":"Очередь 1 - Подготовка","x":-196,"y":-41,"width":250,"height":60},
		{"id":"d753d8bd5d8be09a","type":"text","text":"Разметка - Частотный крит. регресс","x":-196,"y":160,"width":250,"height":60},
		{"id":"3c3e8ec333d6a374","type":"text","text":"На приемке","x":-660,"y":-1440,"width":250,"height":60},
