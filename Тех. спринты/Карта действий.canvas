		{"id":"c6e85d2f58f35f82","type":"text","text":"Акутальный","x":-160,"y":-1440,"width":250,"height":60},
		{"id":"510c4de0c6af3bf8","type":"text","text":"Регресс","x":90,"y":-1440,"width":250,"height":60},
		{"id":"76c53c8654b0db6b","type":"text","text":"Нет ТК без статусов","x":-871,"y":-860,"width":260,"height":60},
		{"id":"5fdb15b7bf33462f","type":"text","text":"Исключен из ТМ","x":-1660,"y":-1440,"width":250,"height":60},
		{"id":"9aaea569d5b4021f","type":"text","text":"Черновик","x":-1410,"y":-1440,"width":250,"height":60},
