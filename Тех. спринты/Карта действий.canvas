		{"id":"83e2cdf60637dcd7","type":"text","text":"Нет ТК без приоритетов","x":-785,"y":-1920,"width":250,"height":60},
		{"id":"bdce70576a0707d7","type":"text","text":"проверить дейстительно ли исключен или тест на функционал нужен, но он не переписан?","x":-1780,"y":-1640,"width":313,"height":104},
